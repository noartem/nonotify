{
  "name": "nonotify",
  "version": "0.2.0",
  "description": "nnt CLI for Telegram notifications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "nnt": "./dist/cli.js"
  },
  "scripts": {
    "prettier:check": "npx prettier --check \"src/**/*.ts\"",
    "prettier:fix": "npx prettier --write \"src/**/*.ts\"",
    "copy:readme": "node ./scripts/copy-readme.mjs",
    "check": "npm run prettier:check",
    "fix": "npm run prettier:fix",
    "test": "npm run check",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run copy:readme && npm run build",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "cli",
    "telegram",
    "notifications",
    "incur"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "cli-table3": "^0.6.5",
    "incur": "^0.3.13"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
